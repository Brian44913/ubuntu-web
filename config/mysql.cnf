# MySQL 8.4 LTS Configuration (Production Optimized)
# MySQL 8.4 LTS 配置文件（生产优化版）

[client]
port = 3306
socket = /var/run/mysqld/mysqld.sock
default-character-set = utf8mb4

[mysql]
prompt="MySQL [\\d]> "
no-auto-rehash

[mysqld]
port = 3306
socket = /var/run/mysqld/mysqld.sock
pid-file = /var/run/mysqld/mysqld.pid
user = mysql
bind-address = 127.0.0.1
server-id = 1

# Character set / 字符集
init-connect = 'SET NAMES utf8mb4'
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci

# NOTE: default_authentication_plugin removed in 8.4
# MySQL 8.4 always uses caching_sha2_password
# 注意：8.4 已移除 default_authentication_plugin，强制使用 caching_sha2_password

skip-name-resolve
back_log = 300

# Connection limits / 连接限制
max_connections = 1000
max_connect_errors = 6000
open_files_limit = 65535
table_open_cache = 4000
max_allowed_packet = 128M
binlog_cache_size = 1M
tmp_table_size = 64M
max_heap_table_size = 64M

# Buffer settings / 缓冲区设置
read_buffer_size = 2M
read_rnd_buffer_size = 8M
sort_buffer_size = 8M
join_buffer_size = 8M
key_buffer_size = 8M
thread_cache_size = 16

# Binary log / 二进制日志
log_bin = mysql-bin
# NOTE: binlog_format removed in 8.4, only ROW-based replication is supported
# 注意：8.4 已移除 binlog_format，仅支持 ROW 格式
binlog_expire_logs_seconds = 604800

# Logging / 日志
log_error = /var/log/mysql/error.log
log_timestamps = SYSTEM
slow_query_log = 1
long_query_time = 1
slow_query_log_file = /var/log/mysql/mysql-slow.log

# Performance schema (required for monitoring tools like sys schema, PMM)
# 性能模式（监控工具依赖，如 sys schema、PMM）
performance_schema = ON

# InnoDB settings / InnoDB 设置
default_storage_engine = InnoDB
innodb_file_per_table = 1
innodb_open_files = 500

# Adjust to 50-70% of available RAM. Examples:
#   4GB server -> 2G, 8GB server -> 4G-5G, 16GB server -> 10G
# 根据服务器可用内存调整为 50-70%
innodb_buffer_pool_size = 1G

innodb_write_io_threads = 4
innodb_read_io_threads = 4
innodb_thread_concurrency = 0
innodb_purge_threads = 4
innodb_log_buffer_size = 16M

# innodb_flush_log_at_trx_commit = 2: flush to OS cache per commit, disk sync per second
# Maximum 1 second of data loss on crash. Use = 1 for full ACID compliance.
# 每次提交写入 OS 缓存，每秒刷盘。崩溃最多丢失 1 秒数据。需要完整 ACID 保证请改为 1
innodb_flush_log_at_trx_commit = 2

# Bypass OS cache for InnoDB data files (avoids double buffering)
# 绕过 OS 缓存直接写入磁盘（避免 InnoDB 和 OS 双重缓冲）
innodb_flush_method = O_DIRECT

# NOTE: innodb_log_file_size and innodb_log_files_in_group removed in 8.4
# Use innodb_redo_log_capacity instead
# 注意：8.4 已移除 innodb_log_file_size 和 innodb_log_files_in_group
innodb_redo_log_capacity = 512M

innodb_max_dirty_pages_pct = 90
innodb_lock_wait_timeout = 120

# SSD I/O capacity (adjust for your disk type)
# SSD IOPS 容量（根据磁盘类型调整，HDD 用默认 200）
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000

# Timeout / 超时
interactive_timeout = 28800
wait_timeout = 28800

[mysqldump]
quick
max_allowed_packet = 128M
